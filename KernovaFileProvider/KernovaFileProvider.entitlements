<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App-identity entitlement fileproviderd uses to launch/validate this sandboxed
	     extension. A provisioning profile normally injects it; the Debug config signs
	     profile-less (Manual), so we declare it explicitly, floating with whichever
	     team DEVELOPMENT_TEAM resolves to (derived per-developer by `make bootstrap`,
	     #476) rather than a hardcoded team. Without it, adding the File Provider domain
	     fails with NSFileProviderError -2001 ("The application cannot be used right
	     now"). Release signs Automatic and its profile injects the same value, so this
	     is harmless there. -->
	<key>com.apple.application-identifier</key>
	<string>$(DEVELOPMENT_TEAM).$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<!-- Shares the KERNOVA_APP_GROUP container the host app registers so this sandboxed
	     extension can read the files the app stages there (addressing is via
	     NSFileProviderServicing, not a Mach service, #460). The identifier is the
	     per-configuration build setting: Debug = $(DEVELOPMENT_TEAM).app.kernova
	     (Team-ID-prefixed, silent access with no provisioning profile — macOS 15
	     criterion C); Release = group.app.kernova (canonical iOS-style, profile-authorized
	     under Automatic signing, MAS-compatible). Host uses a distinct domain id /
	     container subpath, so sharing the same group never collides with the guest. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>$(KERNOVA_APP_GROUP)</string>
	</array>
</dict>
</plist>
