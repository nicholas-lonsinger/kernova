<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App-identity entitlement the system uses to launch/identify the sandboxed
	     extension. A provisioning profile normally injects this; with profile-less
	     manual signing (Option A) we declare it explicitly (team-prefixed bundle id),
	     mirroring KernovaFileProvider. -->
	<key>com.apple.application-identifier</key>
	<string>8MT4P4GZL2.app.kernova.clipboard.fileprovider</string>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<!-- Shares the group the host app registers so the sandboxed extension can read
	     the files the app stages into the group container (addressing is via
	     NSFileProviderServicing, not a Mach service, #460). Stays team-ID-prefixed
	     so it is granted implicitly under profile-less manual signing. Host uses a
	     distinct domain id / container subpath, so sharing the same group never
	     collides with the guest. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>8MT4P4GZL2.app.kernova</string>
	</array>
</dict>
</plist>
