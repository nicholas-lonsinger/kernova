<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App-identity entitlement the system uses to launch/identify the agent and its
	     embedded extension. A provisioning profile normally injects it; the Debug config
	     signs profile-less (Manual), so we declare it explicitly, floating with whichever
	     team DEVELOPMENT_TEAM resolves to (derived per-developer by `make bootstrap`,
	     #476) rather than a hardcoded team. Release signs Manual with the "Kernova macOS
	     Agent Developer ID" profile, which injects the same value. -->
	<key>com.apple.application-identifier</key>
	<string>$(DEVELOPMENT_TEAM).$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<!-- Shared with the embedded KernovaMacOSAgentFileProvider extension so the sandboxed
	     extension can exchange materialized files through the group container
	     (addressing is via NSFileProviderServicing, not a Mach service, #460). The
	     identifier is the per-configuration build setting KERNOVA_APP_GROUP:
	     • Debug = $(DEVELOPMENT_TEAM).app.kernova — a Team-ID-prefixed group. macOS grants
	       silent container access when the group prefix matches the signing team (macOS 15
	       app-group protection, criterion C), so a Debug build needs NO provisioning
	       profile, no portal registration, and no guest-VM UDID registration. Crucially,
	       this means the agent no longer shows the one-time per-app-instance "access data
	       from other apps" consent prompt inside an unregistered guest VM.
	     • Release = group.app.kernova — the canonical iOS-style identifier, authorized by
	       the embedded Developer ID provisioning profile (Manual signing); the same group
	       the host app registers. Developer ID profiles aren't device-locked, so the
	       agent validates inside unregistered guest VMs — unlike a Development profile,
	       which would still prompt there.
	     The agent itself is intentionally NOT sandboxed (it opens vsock); an app group
	     does not require the App Sandbox. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>$(KERNOVA_APP_GROUP)</string>
	</array>
</dict>
</plist>
