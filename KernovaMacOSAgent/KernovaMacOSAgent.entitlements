<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App-identity entitlement (team-prefixed bundle id). Declared explicitly
	     because Option A uses profile-less manual signing so the agent runs in any
	     guest VM without a device-limited provisioning profile. -->
	<key>com.apple.application-identifier</key>
	<string>8MT4P4GZL2.app.kernova.macosagent</string>
	<!-- Shared with the embedded KernovaMacOSAgentFileProvider extension so the sandboxed
	     extension can exchange materialized files through the group container
	     (addressing is via NSFileProviderServicing, not a Mach service, #460). Stays
	     team-ID-prefixed so it is granted implicitly under profile-less manual
	     signing — the agent runs in any guest VM without a device-limited profile.
	     The agent itself is intentionally NOT sandboxed (it opens vsock); an app
	     group does not require the App Sandbox. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>8MT4P4GZL2.app.kernova</string>
	</array>
</dict>
</plist>
